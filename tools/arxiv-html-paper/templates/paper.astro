---
import PaperReaderLayout from "{{LAYOUT_IMPORT}}";
---
<PaperReaderLayout
  title="{{TITLE}}"
  description="{{DESCRIPTION}}"
  arxivId="{{ARXIV_ID}}"
  category="{{CATEGORY}}"
>
  <nav class="ltx_page_navbar" slot="toc">
    <nav class="ltx_TOC">
      <ol class="ltx_toclist">
        <li class="ltx_tocentry ltx_tocentry_abstract"><a href="#abstract1" title="In {{TITLE}}" class="ltx_ref"><span class="ltx_text ltx_ref_title">Abstract.</span></a></li>
        <li class="ltx_tocentry ltx_tocentry_section"><a href="#S1" title="In {{TITLE}}" class="ltx_ref"><span class="ltx_text ltx_ref_title"><span class="ltx_tag ltx_tag_ref">1 </span>Introduction</span></a></li>
        <li class="ltx_tocentry ltx_tocentry_section"><a href="#S2" title="In {{TITLE}}" class="ltx_ref"><span class="ltx_text ltx_ref_title"><span class="ltx_tag ltx_tag_ref">2 </span>Model</span></a></li>
        <li class="ltx_tocentry ltx_tocentry_section"><a href="#S3" title="In {{TITLE}}" class="ltx_ref"><span class="ltx_text ltx_ref_title"><span class="ltx_tag ltx_tag_ref">3 </span>Discussion</span></a></li>
        <li class="ltx_tocentry ltx_tocentry_bibliography"><a href="#references" title="In {{TITLE}}" class="ltx_ref"><span class="ltx_text ltx_ref_title">References</span></a></li>
      </ol>
    </nav>
  </nav>

  <article class="ltx_document ltx_authors_1line ltx_leqno">
    <h1 class="ltx_title ltx_title_document">{{TITLE}}</h1>
    <div class="ltx_authors">
      <span class="ltx_creator ltx_role_author">
        <span class="ltx_personname">{{AUTHOR}}</span>
      </span>
    </div>
    <div class="ltx_dates">{{DATE_LABEL}}</div>

    <div id="abstract1" class="ltx_abstract">
      <h6 class="ltx_title ltx_title_abstract">Abstract.</h6>
      <p class="ltx_p">{{ABSTRACT}}</p>
    </div>
    <div class="ltx_keywords">
      <h6 class="ltx_title ltx_title_keywords">Keywords: </h6>{{KEYWORDS}}
    </div>
    <div class="ltx_classification">
      <h6 class="ltx_title ltx_title_classification">Classification: </h6>{{CATEGORY}}
    </div>

    <section id="S1" class="ltx_section">
      <h2 class="ltx_title ltx_title_section"><span class="ltx_tag ltx_tag_section">1. </span>Introduction</h2>
      <div class="ltx_para">
        <p class="ltx_p">Replace this paragraph with the research object, motivation, and boundary conditions of the paper.</p>
      </div>
    </section>

    <section id="S2" class="ltx_section">
      <h2 class="ltx_title ltx_title_section"><span class="ltx_tag ltx_tag_section">2. </span>Model</h2>
      <div class="ltx_para">
        <p class="ltx_p">Use LaTeXML-style semantic classes for definitions, tables, figures, equations, listings, and references.</p>
      </div>
      <div class="ltx_listing">
        <span class="ltx_listingline"><span class="ltx_lstlisting ltx_text ltx_font_typewriter">input</span></span>
        <span class="ltx_listingline"><span class="ltx_lstlisting ltx_text ltx_font_typewriter">  -&gt; state</span></span>
        <span class="ltx_listingline"><span class="ltx_lstlisting ltx_text ltx_font_typewriter">  -&gt; transition</span></span>
        <span class="ltx_listingline"><span class="ltx_lstlisting ltx_text ltx_font_typewriter">  -&gt; output</span></span>
      </div>
    </section>

    <section id="S3" class="ltx_section">
      <h2 class="ltx_title ltx_title_section"><span class="ltx_tag ltx_tag_section">3. </span>Discussion</h2>
      <div class="ltx_para">
        <p class="ltx_p">Record assumptions, limitations, validation evidence, and open questions here.</p>
      </div>
    </section>

    <section id="references" class="ltx_section ltx_bibliography">
      <h2 class="ltx_title ltx_title_section">References</h2>
      <ol>
        <li>arXiv HTML papers accessible HTML resources.</li>
      </ol>
    </section>
  </article>
</PaperReaderLayout>
