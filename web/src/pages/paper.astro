        <span class="ltx_listingline"><span class="ltx_lstlisting ltx_text ltx_font_typewriter">技术 T</span></span>
        <span class="ltx_listingline"><span class="ltx_lstlisting ltx_text ltx_font_typewriter">  -&gt; 中间变量 X</span></span>
        <span class="ltx_listingline"><span class="ltx_lstlisting ltx_text ltx_font_typewriter">  -&gt; 主体状态 S</span></span>
