---
import ResearchLayout from "../layouts/ResearchLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import MetricGrid from "../components/MetricGrid.astro";

const metrics = [
  {label: "核心对象", value: "主体持续性", note: "能够继续存在、行动、学习和修正的主体"},
  {label: "建模目标", value: "生命路径", note: "寿命、有效时间、主观时间、相对时间和选择权"},
  {label: "图表工具", value: "D3", note: "定制机制图和预测曲线"},
  {label: "页面框架", value: "Astro", note: "长文叙事、静态发布和组件化页面"}
];
---
<ResearchLayout
  title="Human Infra × 奇点更近"
  description="Human Infra research narrative page for subject continuity and life-path modeling"
  section="Research Narrative"
>
  <div class="page">
    <Hero
      kicker="Research Narrative / Life-Path Model"
      title="把奇点叙事接入人类基础设施"
      lead="这不是一页普通书摘，而是一套研究型网页：把《奇点更近》的宏大技术叙事拆成变量、因果链、证据边界和生命路径模型，解释它如何影响主体持续性、有效时间和未来选择权。"
      tags={["书籍转译", "主体持续性", "概率分布", "长寿逃逸速度", "D3 可视化", "科研标准"]}
      chart
    />

    <MetricGrid items={metrics} />

    <section class="section" id="thesis">
      <SectionHeader
        kicker="Core Thesis"
        title="这个网页要展示的不是未来幻想，而是研究对象的形成"
        lead="Human Infra 关心的是：当 AI、计算、生物技术、医学、接口、资源和治理同时改变，人类完成任务所依赖的主体系统会怎样被维护、延展或破坏。"
      />
      <div class="article-grid">
        <div class="article-body">
          <div class="paper-panel">
            <h3>主问题</h3>
            <p>一切价值、目标和创造，都预设一个仍然能够行动的主体。主体不是稳定常量，而是由身体、认知、工具、环境、资源、制度和协作共同维持的有限系统。</p>
            <p>《奇点更近》提供的是一组高密度外部语料：加速回报、AI 增强、医学信息化、人机融合、长寿逃逸速度、纳米技术和文明风险。Human Infra 的工作，是把这些语料转译为主体持续性变量。</p>
          </div>
          <div class="paper-panel">
            <h3>转译链</h3>
            <div class="equation-box">技术信号 T
  -> 中间变量 X
  -> 主体状态 S
  -> 风险函数 λ(t)
  -> 生存曲线 S(t)
  -> 寿命 / 有效时间 / 主观时间 / 相对时间 / 未来选择权</div>
          </div>
        </div>
        <aside class="side-index">
          <strong>阅读索引</strong>
          <a href="#thesis">核心命题</a>
          <a href="#signals">六组信号</a>
          <a href="#translation">模型转译</a>
          <a href="#routes">页面路径</a>
        </aside>
      </div>
    </section>

    <section class="section" id="signals">
      <SectionHeader
        kicker="Book Signals"
        title="从《奇点更近》抽取的六组信号"
        lead="这些信号不是直接当成事实结论，而是作为进入 Human Infra 模型的候选变量、假设和叙事材料。"
      />
      <div class="dense-grid">
        {[
          ["01", "加速回报", "计算成本下降，创新成本下降，更多领域被信息化，AI 参与下一轮科学发现。"],
          ["02", "AI 增强", "AI 改变判断质量、学习速度、自动化能力、医学诊断和任务行动密度。"],
          ["03", "医学信息化", "基因组学、蛋白质结构预测、药物发现和个体化检测把生命系统转成可计算对象。"],
          ["04", "长寿逃逸速度", "当医学进步速度接近或超过年龄消耗，寿命边界从固定终局转向开放临界。"],
          ["05", "人机接口", "脑机接口和云端新皮质设想进入认知容量、记忆外部化、身份连续性和工具耦合问题。"],
          ["06", "风险治理", "核、生物、纳米和 AI 风险说明强技术收益必须与治理能力共同建模。"]
        ].map(([num, title, text]) => (
          <article class="numbered-panel">
            <span>{num}</span>
            <div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="translation">
      <SectionHeader
        kicker="Translation"
        title="Human Infra 的转译不是概念搬运，而是模型定位"
        lead="每个概念进入项目时，都要回答它改变什么变量、处在什么模型位置、能支持什么结论、不能外推到哪里。"
      />
      <table class="data-table">
        <thead>
          <tr>
            <th>书中概念</th>
            <th>Human Infra 转译</th>
            <th>网页表达</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>奇点</td>
            <td>智能、生命、制造和治理系统的共同加速阶段。</td>
            <td>首页机制图和书籍转译页。</td>
          </tr>
          <tr>
            <td>长寿逃逸速度</td>
            <td>寿命边界是否从固定终局转向开放临界。</td>
            <td>模型页的 LEV 阈值和预测有效寿命曲线。</td>
          </tr>
          <tr>
            <td>AI 与人类融合</td>
            <td>主体能力向量被工具、接口和外部智能放大。</td>
            <td>资源预算、能力增益和模型干预项。</td>
          </tr>
          <tr>
            <td>风险治理</td>
            <td>技术收益和尾部风险共同决定未来路径分布。</td>
            <td>科研标准页和模型治理说明。</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section class="section" id="routes">
      <SectionHeader
        kicker="Routes"
        title="页面路径"
        lead="这套网页按研究作品组织，而不是按宣传页组织。读者可以从书籍、模型或科研标准任一路径进入。"
      />
      <div class="dense-grid">
        <a class="paper-panel link-panel" href="/book/">
          <h3>书籍转译</h3>
          <p>把《奇点更近》的核心问题、章节主线、概念定义、因果链、证据边界和误读点转成 Human Infra 语料。</p>
        </a>
        <a class="paper-panel link-panel" href="/model/">
          <h3>预测模型</h3>
          <p>用交互控件展示技术变量如何改变风险函数、生存曲线、LEV 阈值、有效时间和通用资源预算。</p>
        </a>
        <a class="paper-panel link-panel" href="/research-standards/">
          <h3>科研标准</h3>
          <p>沉淀论文阅读、生存分析、因果推断、预测报告规范、可视化工具和模型治理要求。</p>
        </a>
      </div>
    </section>

    <footer class="page-footer">
      研究展示用途。不提供个体医疗建议，不输出个体死亡日期，不把书中预测写成已经实现的事实。
    </footer>
  </div>
  <script>
    import "../scripts/model-charts.js";
  </script>
</ResearchLayout>
