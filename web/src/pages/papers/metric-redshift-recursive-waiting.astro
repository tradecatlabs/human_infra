              <tr>
                <td>{row.id}</td>
                <td>{row.assumption}</td>
                <td>{row.role}</td>
                <td>{row.usedBy.join(", ")}</td>
                <td>{row.failureMode}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="ltx_table">
        <table>
          <thead><tr><th>命题</th><th>陈述</th><th>公式</th><th>依赖假设</th><th>解释 / 非声明</th></tr></thead>
          <tbody>
            {propositionRows.map((row) => (
              <tr>
                <td>{row.id}<br />{row.type}</td>
