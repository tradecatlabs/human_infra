import PaperReaderLayout from "../../layouts/PaperReaderLayout.astro";
import metricData from "../../data/metric-redshift-recursive-waiting.json";
import citationContextPacket from "../../data/metric-redshift-recursive-waiting/CITATION_CONTEXT_REVIEW_PACKET.json";
import citationContextLocalReview from "../../data/metric-redshift-recursive-waiting/CITATION_CONTEXT_LOCAL_REVIEW.json";
import scenarioEvaluationAudit from "../../data/metric-redshift-recursive-waiting/SCENARIO_EVALUATION_AUDIT.json";

const contributionRows = metricData.contributionRegister;
const sourceByKey = new Map(metricData.sourceCards.map((source) => [source.key, source]));
const claimById = new Map(metricData.claimRegister.map((claim) => [claim.id, claim]));
const claimEvidenceRows = metricData.claimEvidenceMap.map((entry) => ({
  ...entry,
  claim: claimById.get(entry.claimId),
  sourceLabels: entry.sourceKeys.map((key) => sourceByKey.get(key)?.title || key).join("；"),
  variableLabels: entry.requiredVariables.join(", "),
}));
const claimMaturityRows = metricData.claimMaturityRegister.map((entry) => ({
  ...entry,
  claim: claimById.get(entry.claimId),
}));
const falsifierRows = metricData.falsifierRegister.map((entry) => ({
  ...entry,
  claim: claimById.get(entry.claimId),
}));
const variableRows = metricData.variableDictionary;
const modelAssumptionRows = metricData.modelAssumptions;
const propositionRows = metricData.propositionRegister;
const figurePlanRows = metricData.figurePlan;
const citationContextRows = metricData.citationContextRegister;
const citationContextLocalReviewRows = citationContextLocalReview.details.contextReviews;
const scenarioTemplateRows = metricData.scenarioCardTemplate.requiredCards;
const scenarioEvaluationRows = metricData.scenarioEvaluationRegistry;
const scenarioById = new Map(metricData.scenarioEvaluationRegistry.map((scenario) => [scenario.id, scenario]));
const toyNcgSpec = metricData.toyNcgEvaluationSpec;
const toyNcgInputRows = toyNcgSpec.inputContract;
const toyNcgStepRows = toyNcgSpec.evaluationSteps;
const toyNcgEvaluationRows = metricData.toyNcgEvaluationRegistry.map((entry) => ({
  ...entry,
  scenario: scenarioById.get(entry.scenarioId),
  inputSummary: entry.normalizedInputs.map((input) => `${input.symbol}: ${input.status} - ${input.notes}`).join("；"),
}));
const scenarioEvaluationAuditRows = scenarioEvaluationAudit.evaluations;
const ncgFormulaFigure = metricData.ncgFormulaDecompositionFigure;
const ncgFormulaBlockRows = ncgFormulaFigure.blocks;
const preSubmissionReviewRows = metricData.preSubmissionReviewRegister;
const sourceLedgerRows = metricData.sourceCardLedger.map((entry) => ({
  ...entry,
  source: sourceByKey.get(entry.sourceKey),
  claimLabels: entry.mappedClaims.map((claimId) => `${claimId}: ${claimById.get(claimId)?.claimType || "unknown"}`).join("；"),
  variableLabels: entry.mappedVariables.join(", "),
}));
