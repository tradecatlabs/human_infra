const minimalEvaluatorOutputRows = metricData.minimalEvaluatorOutputExamples;
const scenarioEvaluationAuditRows = scenarioEvaluationAudit.evaluations;
const ncgFormulaFigure = metricData.ncgFormulaDecompositionFigure;
const ncgFormulaBlockRows = ncgFormulaFigure.blocks;
const preSubmissionReviewRows = metricData.preSubmissionReviewRegister;
const reviewDecisionRows = metricData.reviewDecisionRegister;
const missingEvidenceRows = metricData.missingEvidenceRegister;
const sourceLedgerRows = metricData.sourceCardLedger.map((entry) => ({
  ...entry,
  source: sourceByKey.get(entry.sourceKey),
  claimLabels: entry.mappedClaims.map((claimId) => `${claimId}: ${claimById.get(claimId)?.claimType || "unknown"}`).join("；"),
  variableLabels: entry.mappedVariables.join(", "),
}));
const propositionFormulaHtml = {
  "MRW-P1": `<div class="ltx_eqn_div"><math display="block"><mrow><msub><mi>K</mi><mi>i</mi></msub><mo>=</mo><mfrac><mrow><mi>Δ</mi><msub><mi>T</mi><mrow><mi>External</mi></mrow></msub><mo>_</mo><mi>i</mi></mrow><mrow><mi>Δ</mi><msub><mi>τ</mi><mrow><mi>Subject</mi></mrow></msub><mo>_</mo><mi>i</mi></mrow></mfrac></mrow></math></div>`,
  "MRW-P2": `<div class="ltx_eqn_div"><math display="block"><mrow><msub><mtext>NCG-Screen</mtext><mi>i</mi></msub><mo>=</mo><mtext>GateCheck</mtext><mo>(</mo><mo>…</mo><mo>)</mo></mrow></math></div>`,
  "MRW-P3": `<div class="ltx_eqn_div"><math display="block"><mtable columnalign="left"><mtr><mtd><msub><mi>Θ</mi><mrow><mi>i</mi><mo>+</mo><mn>1</mn></mrow></msub><mo>=</mo><mi>F</mi><mo>(</mo><msub><mi>Θ</mi><mi>i</mi></msub><mo>,</mo><msub><mtext>Upgrade</mtext><mi>i</mi></msub><mo>)</mo></mtd></mtr><mtr><mtd><msub><mtext>NCG</mtext><mrow><mi>i</mi><mo>+</mo><mn>1</mn></mrow></msub><mo>(</mo><msub><mi>Θ</mi><mrow><mi>i</mi><mo>+</mo><mn>1</mn></mrow></msub><mo>)</mo><mo>&gt;</mo><msub><mtext>NCG</mtext><mi>i</mi></msub><mo>(</mo><msub><mi>Θ</mi><mi>i</mi></msub><mo>)</mo></mtd></mtr></mtable></math></div>`,
  "MRW-P4": `<div class="ltx_eqn_div"><math display="block"><mrow><mtext>Abort if </mtext><msub><mi>PExit</mi><mi>i</mi></msub><mo>=</mo><mn>0</mn><mo> or </mo><msub><mi>PContinuity</mi><mi>i</mi></msub><mo>=</mo><mn>0</mn><mo> or </mo><msub><mi>RTail</mi><mi>i</mi></msub><mo>&gt;</mo><mtext>threshold</mtext></mrow></math></div>`,
};
