        </table>
      </div>
      <p class="ltx_p"><strong>子问题。</strong>{researchQuestionBrief.subQuestions.join("；")}</p>
      <p class="ltx_p"><strong>范围。</strong>In scope: {researchQuestionBrief.scope.inScope.join("；")}。Out of scope: {researchQuestionBrief.scope.outOfScope.join("；")}。</p>

