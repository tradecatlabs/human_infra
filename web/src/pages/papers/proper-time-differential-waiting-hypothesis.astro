const ncgRatingStyles = {
  high: { label: "高", fill: "#0077BB", text: "#ffffff" },
  medium: { label: "中", fill: "#33BBEE", text: "#111111" },
  low: { label: "低", fill: "#BBBBBB", text: "#111111" },
  blocked: { label: "阻", fill: "#CC3311", text: "#ffffff" },
  missing: { label: "缺", fill: "#EE7733", text: "#111111" },
  "not-applicable": { label: "无", fill: "#f5f5f5", text: "#555555" }
};

const getRatingStyle = (rating) => ncgRatingStyles[rating] ?? ncgRatingStyles.missing;
const matrixLeft = 168;
const matrixTop = 72;
const matrixCellWidth = 70;
const matrixCellHeight = 42;
const matrixWidth = ncgMetricColumns.length * matrixCellWidth;
const statusLeft = matrixLeft + matrixWidth + 18;
const figureWidth = 940;
const figureHeight = matrixTop + scenarioVariableRows.length * matrixCellHeight + 116;
